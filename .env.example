APP_NAME="SocietyMan Enterprise ERP API"
API_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
DATABASE_URL=postgresql+psycopg://societyman:societyman@localhost:5432/societyman
POSTGRES_DATABASE_URL=postgresql+psycopg://societyman:societyman@postgres:5432/societyman
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=30
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe@12345
DEFAULT_ADMIN_NAME="Developer Admin"
DEFAULT_ADMIN_PHONE=0000000000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
WHATSAPP_PROVIDER=meta
WHATSAPP_META_TOKEN=
WHATSAPP_META_PHONE_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM=your-gmail-address@gmail.com
SMTP_USE_TLS=true
