generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  society_admin
  manager
  resident
  gatekeeper
  vendor
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  region    String    @default("IN")
  plan      String    @default("starter")
  isActive  Boolean   @default(true)
  records   ERPRecord[]
  auditLogs AuditLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug, isActive])
}

model Company {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  gstin     String?
  currency  String   @default("INR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([tenantId, deletedAt])
}

model User {
  id          String    @id @default(uuid())
  tenantId    String?
  fullName    String
  email       String    @unique
  phone       String    @unique
  passwordHash String
  role        Role
  isActive    Boolean   @default(true)
  mfaEnabled  Boolean   @default(false)
  lastLoginAt DateTime?
  auditLogs   AuditLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, role, isActive])
}

model ERPRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  moduleKey   String
  recordType  String
  title       String
  status      String   @default("draft")
  payload     Json
  ownerUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([tenantId, moduleKey, status, deletedAt])
  @@index([recordType, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, action, createdAt])
  @@index([actorUserId, createdAt])
}

model WorkflowDefinition {
  id         String   @id @default(uuid())
  tenantId   String
  key        String
  name       String
  trigger    String
  definition Json
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, trigger, isActive])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  title     String
  body      String
  channel   String   @default("in-app")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, userId, isRead, createdAt])
}

model IntegrationEndpoint {
  id         String   @id @default(uuid())
  tenantId   String
  provider   String
  name       String
  status     String   @default("planned")
  webhookUrl String?
  config     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, provider, status])
}

model Asset {
  id                   String    @id @default(uuid())
  tenantId             String
  societyId            String
  name                 String
  category             String
  location             String
  vendorId             String?
  manufacturer         String?
  modelNumber          String?
  purchaseValue        Decimal   @default(0)
  installedAt          DateTime?
  warrantyExpiresAt    DateTime?
  amcExpiresAt         DateTime?
  maintenanceCycleDays Int       @default(90)
  status               String    @default("active")
  createdAt            DateTime  @default(now())

  @@index([tenantId, societyId, category, status])
  @@index([amcExpiresAt])
}

model InventoryItem {
  id          String   @id @default(uuid())
  tenantId    String
  societyId   String
  name        String
  sku         String
  category    String
  location    String   @default("main store")
  quantity    Decimal  @default(0)
  minQuantity Decimal  @default(0)
  unitCost    Decimal  @default(0)
  vendorId    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([tenantId, societyId, category])
  @@index([sku])
}

model StaffMember {
  id            String   @id @default(uuid())
  tenantId      String
  societyId     String
  fullName      String
  phone         String
  role          String
  department    String?
  shiftName     String?
  idProofType   String?
  idProofNumber String?
  passcode      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([tenantId, societyId, role, isActive])
  @@index([phone])
}

model StaffAttendance {
  id            String    @id @default(uuid())
  tenantId      String
  societyId     String
  staffMemberId String
  checkInAt     DateTime  @default(now())
  checkOutAt    DateTime?
  status        String    @default("present")

  @@index([tenantId, societyId, checkInAt, checkOutAt])
}

model Vehicle {
  id                 String   @id @default(uuid())
  tenantId           String
  societyId          String
  unitId             String?
  ownerUserId        String?
  registrationNumber String
  vehicleType        String   @default("car")
  stickerNumber      String?
  parkingSlot        String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([tenantId, societyId, isActive])
  @@index([registrationNumber])
}

model GatePass {
  id              String    @id @default(uuid())
  tenantId        String
  societyId       String
  issuedToName    String
  issuedToPhone   String?
  passType        String    @default("material")
  purpose         String?
  status          String    @default("issued")
  validFrom       DateTime  @default(now())
  validUntil      DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  @@index([tenantId, societyId, status, validFrom])
}

model PurchaseRequest {
  id                String    @id @default(uuid())
  tenantId          String
  societyId         String
  requestedByUserId String
  vendorId          String?
  title             String
  description       String?
  amount            Decimal   @default(0)
  status            String    @default("pending")
  approvalLevel     String    @default("committee")
  approvedByUserId  String?
  approvedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([tenantId, societyId, status, createdAt])
}

model AmenityBooking {
  id             String   @id @default(uuid())
  tenantId       String
  societyId      String
  amenityName    String
  unitId         String?
  residentUserId String
  startsAt       DateTime
  endsAt         DateTime
  amount         Decimal  @default(0)
  status         String   @default("booked")
  paymentStatus  String   @default("unpaid")
  createdAt      DateTime @default(now())

  @@index([tenantId, societyId, amenityName, startsAt])
  @@index([residentUserId, startsAt])
}

model ComplianceEvent {
  id          String    @id @default(uuid())
  tenantId    String
  societyId   String
  eventType   String
  title       String
  description String?
  status      String    @default("open")
  dueAt       DateTime?
  closedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, societyId, eventType, status])
  @@index([dueAt])
}
